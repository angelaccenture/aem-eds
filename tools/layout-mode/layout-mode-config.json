{
  "defaults": {
    "blocks": {
      "*": {
        "actions": ["move-up", "move-down", "delete", "duplicate"]
      },
      "hero": {
        "label": "Hero",
        "properties": [
          { "name": "classes", "type": "multi-select", "source": "da", "path": "/docs/library/styles/hero" }
        ]
      },
      "card": {
        "label": "Card",
        "properties": [
          { "name": "classes", "type": "multi-select", "source": "da", "path": "/docs/library/styles/card" }
        ]
      },
      "teaser": {
        "label": "Teaser",
        "properties": [
          { "name": "classes", "type": "multi-select", "source": "da", "path": "/docs/library/styles/teaser" }
        ]
      },
      "columns": {
        "label": "Columns",
        "properties": [
          { "name": "classes", "type": "multi-select", "source": "da", "path": "/docs/library/styles/columns" }
        ]
      },
      "advanced-accordion": {
        "label": "Accordion",
        "properties": [
          { "name": "classes", "type": "multi-select", "source": "da", "path": "/docs/library/styles/advanced-accordion" }
        ]
      },
      "advanced-carousel": {
        "label": "Carousel",
        "properties": [
          { "name": "classes", "type": "multi-select", "source": "da", "path": "/docs/library/styles/advanced-carousel" }
        ]
      },
      "advanced-tabs": {
        "label": "Tabs",
        "properties": [
          { "name": "classes", "type": "multi-select", "source": "da", "path": "/docs/library/styles/advanced-tabs" }
        ]
      }
    },
    "sections": {
      "actions": ["add-block", "move-up", "move-down", "delete"],
      "properties": [
        { "name": "classes", "type": "multi-select", "source": "da", "path": "/docs/library/styles/sections" }
      ]
    }
  },
  "templates": {
    "blog": {
      "blocks": {
        "*": {
          "actions": ["move-up", "move-down", "delete"]
        }
      },
      "sections": {
        "properties": [
          { "name": "style", "type": "multi-select", "source": "da", "path": "/config/section-styles" },
          { "name": "spacing", "type": "select", "options": ["none", "s", "m", "l"] }
        ]
      }
    },
    "homepage": {
      "blocks": {
        "*": {
          "actions": ["move-up", "move-down", "delete", "duplicate", "add-block"]
        },
        "hero": {
          "variants": ["center", "dark", "video"],
          "properties": [
            { "name": "style", "type": "select", "options": ["default", "center", "dark", "video"] }
          ]
        }
      }
    },
    "product": {
      "blocks": {
        "*": {
          "actions": ["move-up", "move-down", "delete", "duplicate"]
        }
      },
      "sections": {
        "properties": [
          { "name": "style", "type": "multi-select", "source": "da", "path": "/config/section-styles" },
          { "name": "grid", "type": "select", "options": ["none", "2", "3", "4"] },
          { "name": "spacing", "type": "select", "options": ["none", "s", "m", "l", "xl"] }
        ]
      }
    }
  }
}
